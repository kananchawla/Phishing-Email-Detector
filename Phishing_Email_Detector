    "import joblib\n",
    "\n",
    "# Function to test new emails\n",
    "def predict_email(email_text):\n",
    "    # Load the saved model and vectorizer\n",
    "    model = joblib.load('phishing_model.pkl')\n",
    "    vectorizer = joblib.load('tfidf_vectorizer.pkl')\n",
    "    \n",
    "    # Transform the new text\n",
    "    text_vector = vectorizer.transform([email_text])\n",
    "    \n",
    "    # Predict\n",
    "    prediction = model.predict(text_vector)\n",
    "    \n",
    "    return \"Phishing\" if prediction[0] == 1 else \"Legitimate\"\n",
    "\n",
    "# --- TEST IT HERE ---\n",
    "# Try changing this text to see how the AI reacts!\n",
    "test_email = \"Hi there, congratulations! You are the winner of a $1000 gift card. Click here to claim.\"\n",
    "print(f\"Email Verdict: {predict_email(test_email)}\")"
   ]
