   "source": [
    "# Check for any missing values\n",
    "print(\"Missing values in each column:\\n\", df.isnull().sum())\n",
    "\n",
    "# We only really need 'text' and 'label' for our model\n",
    "# Let's keep only those two columns to make things cleaner\n",
    "df_clean = df[['text', 'label']].copy()\n",
    "\n",
    "# Drop any rows that might be empty\n",
    "df_clean = df_clean.dropna()\n",
    "\n",
    "print(\"\\nData after cleaning:\")\n",
    "print(df_clean.head())"
   ]
  },
